<Application x:Class="AdvancedCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark Theme Colors -->
            <Color x:Key="PrimaryDark">#FF4FC3F7</Color>
            <Color x:Key="AccentGreen">#FF81C784</Color>
            <Color x:Key="AccentOrange">#FFFFB74D</Color>
            <Color x:Key="AccentRed">#FFEF5350</Color>
            <Color x:Key="BgDark">#FF1E1E2E</Color>
            <Color x:Key="SurfaceDark">#FF2D2D44</Color>
            <Color x:Key="CardDark">#FF363652</Color>
            <Color x:Key="TextPrimaryDark">#FFFFFFFF</Color>
            <Color x:Key="TextSecondaryDark">#FFB0B0C0</Color>

            <!-- Dark Theme -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BgDark}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceDark}" />
            <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardDark}" />
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryDark}" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}" />
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}" />
            <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryDark}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryDark}" />

            <!-- Button Styles -->
            <Style x:Key="CalcButton" TargetType="Button">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource CardBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="3" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="12" 
                                    Padding="8,12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.7" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="NumberButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource CardBrush}" />
            </Style>

            <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource PrimaryDark}" Opacity="0.3" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            </Style>

            <Style x:Key="FunctionButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource AccentOrange}" Opacity="0.2" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}" />
            </Style>

            <Style x:Key="EqualButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
                <Setter Property="FontSize" Value="24" />
            </Style>

            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource AccentRed}" Opacity="0.2" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
