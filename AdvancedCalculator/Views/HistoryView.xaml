<UserControl x:Class="AdvancedCalculator.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8">
            <Grid>
                <TextBlock Text="计算历史" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="清空历史" Style="{StaticResource DangerButton}" 
                        Click="ClearHistory_Click" HorizontalAlignment="Right" Width="90" Height="32" FontSize="13" />
            </Grid>
        </Border>

        <!-- History List -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="8">
            <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     SelectionChanged="History_Selected">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="14,10" Margin="0,0,0,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Expression}" 
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                                <TextBlock Grid.Row="1" Text="{Binding Result}" 
                                           Foreground="{StaticResource AccentGreenBrush}" FontSize="22" FontWeight="Bold" Margin="0,2,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
