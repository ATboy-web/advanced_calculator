<UserControl x:Class="AdvancedCalculator.Views.ScientificCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Display -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Margin="0,0,0,8" Padding="16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="SciExpression" Grid.Row="0" Text="" 
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Right" />
                <TextBlock x:Name="SciResult" Grid.Row="1" Text="0"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="34"
                           FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <!-- Mode Indicator -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,10,0,0">
            <TextBlock x:Name="AngleMode" Text="DEG" Foreground="{StaticResource AccentGreenBrush}" FontSize="11" FontWeight="Bold" />
            <TextBlock x:Name="ShiftMode" Text="" Foreground="{StaticResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold" Margin="10,0,0,0" />
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 1: Shift, π, e, AC, ⌫ -->
            <Button Grid.Row="0" Grid.Column="0" x:Name="BtnShift" Content="2nd" Style="{StaticResource FunctionButton}" Click="Shift_Click" FontSize="14" />
            <Button Grid.Row="0" Grid.Column="1" Content="π" Style="{StaticResource FunctionButton}" Click="Constant_Click" Tag="pi" FontSize="16" />
            <Button Grid.Row="0" Grid.Column="2" Content="e" Style="{StaticResource FunctionButton}" Click="Constant_Click" Tag="e" FontSize="16" />
            <Button Grid.Row="0" Grid.Column="3" Content="AC" Style="{StaticResource DangerButton}" Click="Clear_Click" />
            <Button Grid.Row="0" Grid.Column="4" Content="⌫" Style="{StaticResource FunctionButton}" Click="Backspace_Click" />

            <!-- Row 2: sin, cos, tan, (, ) -->
            <Button Grid.Row="1" Grid.Column="0" x:Name="BtnSin" Content="sin" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="sin" />
            <Button Grid.Row="1" Grid.Column="1" x:Name="BtnCos" Content="cos" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="cos" />
            <Button Grid.Row="1" Grid.Column="2" x:Name="BtnTan" Content="tan" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="tan" />
            <Button Grid.Row="1" Grid.Column="3" Content="(" Style="{StaticResource OperatorButton}" Click="Paren_Click" Tag="(" />
            <Button Grid.Row="1" Grid.Column="4" Content=")" Style="{StaticResource OperatorButton}" Click="Paren_Click" Tag=")" />

            <!-- Row 3: ln, log, √, x², x^y -->
            <Button Grid.Row="2" Grid.Column="0" x:Name="BtnLn" Content="ln" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="ln" />
            <Button Grid.Row="2" Grid.Column="1" x:Name="BtnLog" Content="log" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="log" />
            <Button Grid.Row="2" Grid.Column="2" Content="√" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="sqrt" />
            <Button Grid.Row="2" Grid.Column="3" Content="x²" Style="{StaticResource OperatorButton}" Click="Square_Click" />
            <Button Grid.Row="2" Grid.Column="4" Content="x^y" Style="{StaticResource OperatorButton}" Click="Operator_Click" Tag="^" />

            <!-- Row 4: 1/x, |x|, n!, 7, 8 -->
            <Button Grid.Row="3" Grid.Column="0" Content="1/x" Style="{StaticResource FunctionButton}" Click="Reciprocal_Click" />
            <Button Grid.Row="3" Grid.Column="1" Content="|x|" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="abs" />
            <Button Grid.Row="3" Grid.Column="2" Content="n!" Style="{StaticResource FunctionButton}" Click="Factorial_Click" />
            <Button Grid.Row="3" Grid.Column="3" Content="7" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="4" Content="8" Style="{StaticResource NumberButton}" Click="Digit_Click" />

            <!-- Row 5: %, ÷, ×, 9, 4 -->
            <Button Grid.Row="4" Grid.Column="0" Content="%" Style="{StaticResource FunctionButton}" Click="Percent_Click" />
            <Button Grid.Row="4" Grid.Column="1" Content="÷" Style="{StaticResource OperatorButton}" Click="Operator_Click" Tag="/" />
            <Button Grid.Row="4" Grid.Column="2" Content="×" Style="{StaticResource OperatorButton}" Click="Operator_Click" Tag="*" />
            <Button Grid.Row="4" Grid.Column="3" Content="9" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="4" Grid.Column="4" Content="4" Style="{StaticResource NumberButton}" Click="Digit_Click" />

            <!-- Row 6: DEG/RAD, 5, 6, -, + -->
            <Button Grid.Row="5" Grid.Column="0" x:Name="BtnAngle" Content="DEG" Style="{StaticResource FunctionButton}" Click="Angle_Click" />
            <Button Grid.Row="5" Grid.Column="1" Content="5" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="5" Grid.Column="2" Content="6" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="5" Grid.Column="3" Content="-" Style="{StaticResource OperatorButton}" Click="Operator_Click" />
            <Button Grid.Row="5" Grid.Column="4" Content="+" Style="{StaticResource OperatorButton}" Click="Operator_Click" />

            <!-- Row 7: exp, ceil, floor, 1, 2 -->
            <Button Grid.Row="6" Grid.Column="0" Content="eˣ" Style="{StaticResource FunctionButton}" Click="Exp_Click" />
            <Button Grid.Row="6" Grid.Column="1" Content="⌈x⌉" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="ceil" />
            <Button Grid.Row="6" Grid.Column="2" Content="⌊x⌋" Style="{StaticResource FunctionButton}" Click="Func_Click" Tag="floor" />
            <Button Grid.Row="6" Grid.Column="3" Content="1" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="6" Grid.Column="4" Content="2" Style="{StaticResource NumberButton}" Click="Digit_Click" />

            <!-- Row 8: ±, 0, ., 3, = -->
            <Button Grid.Row="7" Grid.Column="0" Content="±" Style="{StaticResource FunctionButton}" Click="Negate_Click" />
            <Button Grid.Row="7" Grid.Column="1" Content="0" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="7" Grid.Column="2" Content="." Style="{StaticResource NumberButton}" Click="Decimal_Click" />
            <Button Grid.Row="7" Grid.Column="3" Content="3" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="7" Grid.Column="4" Content="=" Style="{StaticResource EqualButton}" Click="Equals_Click" />
        </Grid>
    </Grid>
</UserControl>
