<UserControl x:Class="AdvancedCalculator.Views.BasicCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Display -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="0,0,0,10" Padding="20,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="ExpressionDisplay" Grid.Row="0" Text="" 
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="18"
                           HorizontalAlignment="Right" Margin="0,0,0,5" />
                <TextBlock x:Name="ResultDisplay" Grid.Row="1" Text="0"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="42"
                           FontWeight="Bold" HorizontalAlignment="Right"
                           VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 1: AC, ⌫, %, ÷ -->
            <Button Grid.Row="0" Grid.Column="0" Content="AC" Style="{StaticResource DangerButton}" Click="Clear_Click" />
            <Button Grid.Row="0" Grid.Column="1" Content="⌫" Style="{StaticResource FunctionButton}" Click="Backspace_Click" />
            <Button Grid.Row="0" Grid.Column="2" Content="%" Style="{StaticResource FunctionButton}" Click="Percent_Click" />
            <Button Grid.Row="0" Grid.Column="3" Content="÷" Style="{StaticResource OperatorButton}" Click="Operator_Click" Tag="/" />

            <!-- Row 2: 7, 8, 9, × -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="3" Content="×" Style="{StaticResource OperatorButton}" Click="Operator_Click" Tag="*" />

            <!-- Row 3: 4, 5, 6, - -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource OperatorButton}" Click="Operator_Click" />

            <!-- Row 4: 1, 2, 3, + -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="3" Content="+" Style="{StaticResource OperatorButton}" Click="Operator_Click" />

            <!-- Row 5: ±, 0, ., = -->
            <Button Grid.Row="4" Grid.Column="0" Content="±" Style="{StaticResource FunctionButton}" Click="Negate_Click" />
            <Button Grid.Row="4" Grid.Column="1" Content="0" Style="{StaticResource NumberButton}" Click="Digit_Click" />
            <Button Grid.Row="4" Grid.Column="2" Content="." Style="{StaticResource NumberButton}" Click="Decimal_Click" />
            <Button Grid.Row="4" Grid.Column="3" Content="=" Style="{StaticResource EqualButton}" Click="Equals_Click" />
        </Grid>
    </Grid>
</UserControl>
