<UserControl x:Class="AdvancedCalculator.Views.EquationSolverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Equation Type Selector -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="RbLinear" Content="一元一次" IsChecked="True" Style="{StaticResource {x:Type RadioButton}}"
                             Foreground="{StaticResource TextPrimaryBrush}" Checked="Type_Changed" Margin="0,0,16,0" />
                <RadioButton x:Name="RbQuadratic" Content="一元二次" Style="{StaticResource {x:Type RadioButton}}"
                             Foreground="{StaticResource TextPrimaryBrush}" Checked="Type_Changed" Margin="0,0,16,0" />
                <RadioButton x:Name="RbSystem" Content="二元一次" Style="{StaticResource {x:Type RadioButton}}"
                             Foreground="{StaticResource TextPrimaryBrush}" Checked="Type_Changed" />
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Linear: ax + b = 0 -->
                <StackPanel x:Name="LinearPanel" Grid.Row="0" Orientation="Horizontal" Visibility="Visible">
                    <TextBlock Text="a=" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="LinA" Text="1" Width="80" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="6,4" FontSize="15" Margin="0,0,16,0" />
                    <TextBlock Text="b=" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="LinB" Text="0" Width="80" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="6,4" FontSize="15" />
                    <TextBlock Text="  →  ax + b = 0" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Quadratic: ax² + bx + c = 0 -->
                <StackPanel x:Name="QuadraticPanel" Grid.Row="1" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="a=" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="QdA" Text="1" Width="70" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="6,4" FontSize="15" Margin="0,0,10,0" />
                    <TextBlock Text="b=" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="QdB" Text="0" Width="70" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="6,4" FontSize="15" Margin="0,0,10,0" />
                    <TextBlock Text="c=" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="QdC" Text="0" Width="70" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="6,4" FontSize="15" />
                </StackPanel>

                <!-- System: a1x + b1y = c1, a2x + b2y = c2 -->
                <StackPanel x:Name="SystemPanel" Grid.Row="2" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBox x:Name="SysA1" Text="1" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                        <TextBlock Text="x + " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBox x:Name="SysB1" Text="1" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                        <TextBlock Text="y = " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBox x:Name="SysC1" Text="3" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="SysA2" Text="2" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                        <TextBlock Text="x + " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBox x:Name="SysB2" Text="-1" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                        <TextBlock Text="y = " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBox x:Name="SysC2" Text="1" Width="50" Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="4,3" FontSize="14" />
                    </StackPanel>
                </StackPanel>

                <!-- Solve Button & Result -->
                <Button Grid.Row="3" Content="求解" Style="{StaticResource EqualButton}" Click="Solve_Click" Margin="0,10,0,0" Height="40" />
            </Grid>
        </Border>

        <!-- Result Display -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ResultText" Text="输入系数后点击求解" 
                           Foreground="{StaticResource AccentGreenBrush}" FontSize="18"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
