<Window x:Class="AdvancedCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AdvancedCalculator.Views"
        Title="高级计算器" Height="750" Width="450"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="650" MinWidth="380">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="8,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnBasic" Content="基础" Click="Nav_Click" Tag="Basic"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
                <Button x:Name="BtnScientific" Content="科学" Click="Nav_Click" Tag="Scientific"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
                <Button x:Name="BtnGraph" Content="绘图" Click="Nav_Click" Tag="Graph"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
                <Button x:Name="BtnEquation" Content="方程" Click="Nav_Click" Tag="Equation"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
                <Button x:Name="BtnConverter" Content="转换" Click="Nav_Click" Tag="Converter"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
                <Button x:Name="BtnHistory" Content="历史" Click="Nav_Click" Tag="History"
                        Style="{StaticResource OperatorButton}" Width="60" Height="36" FontSize="13" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <views:BasicCalculatorView x:Name="BasicView" Visibility="Visible" />
            <views:ScientificCalculatorView x:Name="ScientificView" Visibility="Collapsed" />
            <views:GraphingView x:Name="GraphView" Visibility="Collapsed" />
            <views:EquationSolverView x:Name="EquationView" Visibility="Collapsed" />
            <views:UnitConverterView x:Name="ConverterView" Visibility="Collapsed" />
            <views:HistoryView x:Name="HistoryView" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
